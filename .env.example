# Copy to .env.local and fill in values. Public site URL (no trailing slash).
NEXT_PUBLIC_APP_URL=https://ultrakool-crm.vercel.app
NEXT_PUBLIC_SITE_URL=https://ultrakool-crm.vercel.app

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: log Meta WhatsApp webhook payload shape in server logs (no message text). Vercel → set, redeploy, send test message, then remove.
# WHATSAPP_WEBHOOK_DEBUG=true

# Meta Facebook Login — must match Meta app “Valid OAuth Redirect URIs”
FACEBOOK_REDIRECT_URI=https://ultrakool-crm.vercel.app/api/integrations/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Mcube webhook base (optional; can include ?secret= if required by Mcube)
# MCUBE_REFURL=https://ultrakool-crm.vercel.app/api/webhooks/mcube

# GitHub Actions cron jobs: set repo secret APP_BASE_URL=https://ultrakool-crm.vercel.app

# --- Google Sheet → leads (Supabase Edge Function `sheets-meta-lead`) ---
# In Supabase Dashboard → Edge Function Secrets: add ONLY SHEETS_SYNC_SECRET (long random string).
# Do NOT try to add SUPABASE_URL or SUPABASE_SERVICE_ROLE_KEY there — names starting with SUPABASE_ are
# reserved; those values are already injected into Edge Functions by Supabase.
# Deploy: supabase functions deploy sheets-meta-lead --no-verify-jwt
# Apps Script: Script property CRM_SYNC_SECRET = same value as SHEETS_SYNC_SECRET
