# Copy to .env.local and fill in values. Public site URL (no trailing slash).
NEXT_PUBLIC_APP_URL=https://crm.xcelppf.com
NEXT_PUBLIC_SITE_URL=https://crm.xcelppf.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: log Meta WhatsApp webhook payload shape in server logs (no message text). Vercel → set, redeploy, send test message, then remove.
# WHATSAPP_WEBHOOK_DEBUG=true

# Meta Facebook Login — must match Meta app “Valid OAuth Redirect URIs”
FACEBOOK_REDIRECT_URI=https://crm.xcelppf.com/api/integrations/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# MCUBE click-to-call (each tele-caller uses their own number from Teams → Phone / MCUBE executive)
# MCUBE_API_TOKEN=
# MCUBE_WEBHOOK_SECRET=
# MCUBE_REFURL=https://crm.xcelppf.com/api/webhooks/mcube
# Do NOT set MCUBE_EXECUTIVE_NUMBER — it forces one number for all callers (removed from outbound).

# FastCron HTTP jobs (ONLY scheduler — do not use GitHub Actions / Vercel / Render / pg_cron)
# CRON_SECRET=  # Bearer token — set on web app; FastCron sends Authorization: Bearer <CRON_SECRET>
# See docs/DEPLOYMENT.md for URLs and schedules
# WHATSAPP_AUTOMATION_MAX_RUNTIME_MS=230000
# WHATSAPP_AUTOMATION_MAX_ATTEMPTS_PER_PHONE=25
# WHATSAPP_SCHEDULED_CHUNK_SIZE=40
# WHATSAPP_SCHEDULED_MIN_DELAY_MS=400