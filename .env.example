# Copy to .env.local and fill in values. Public site URL (no trailing slash).
NEXT_PUBLIC_APP_URL=https://crm.ultrakool.com
NEXT_PUBLIC_SITE_URL=https://crm.ultrakool.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: log Meta WhatsApp webhook payload shape in server logs (no message text). Vercel → set, redeploy, send test message, then remove.
# WHATSAPP_WEBHOOK_DEBUG=true

# Meta Facebook Login — must match Meta app “Valid OAuth Redirect URIs”
FACEBOOK_REDIRECT_URI=https://crm.ultrakool.com/api/integrations/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Mcube webhook base (optional; can include ?secret= if required by Mcube)
# MCUBE_REFURL=https://crm.ultrakool.com/api/webhooks/mcube

# GitHub Actions cron jobs: set repo secret APP_BASE_URL=https://crm.ultrakool.com
